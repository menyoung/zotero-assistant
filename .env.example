# Zotero data directory (where zotero.sqlite and storage/ live)
# Default: ~/Zotero on macOS/Linux, C:\Users\<username>\Zotero on Windows
# Check your setting: Zotero > Settings > Advanced > Files and Folders > Data Directory Location
ZOTERO_DATA_DIR=~/Zotero

# Zotero Web API
# For a group library: https://api.zotero.org/groups/<group_id>
# For a personal library: https://api.zotero.org/users/<user_id>
ZOTERO_API_BASE=https://api.zotero.org/groups/your_group_id

# Zotero SQLite libraryID (1 = personal/My Library, 2 = first group library)
ZOTERO_LIBRARY_ID=2

# Zotero API key — create at https://www.zotero.org/settings/keys
ZOTERO_API_KEY=your_zotero_api_key

# Perplexity API key — https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_api_key

# Google AI (Gemini) API key — https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
